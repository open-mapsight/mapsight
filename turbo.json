{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"tasks": {
		"lint": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"clean": {},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				"public/img/mapsight**",
				"src/generated/**"
			]
		},
		"mapsight-host-starter#build": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build",
				"@mapsight/vite-host-embed#build"
			],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				"public/img/mapsight**",
				"src/generated/**"
			]
		},
		"mapsight-next-starter#build": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build"
			],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				"public/img/mapsight**",
				"src/generated/**"
			]
		},
		"mapsight-vite-spa-starter#build": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build"
			],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				"public/img/mapsight**",
				"src/generated/**"
			]
		},
		"watch": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"mapsight-host-starter#typecheck": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build",
				"@mapsight/vite-host-embed#build"
			],
			"outputs": []
		},
		"mapsight-next-starter#typecheck": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build"
			],
			"outputs": []
		},
		"mapsight-vite-spa-starter#typecheck": {
			"dependsOn": [
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/traffic-style#build",
				"@mapsight/ui#build",
				"@mapsight/vector-style-compiler#build"
			],
			"outputs": []
		},
		"//#typecheck:scripts": {
			"outputs": []
		},
		"//#lint:starters": {
			"outputs": [],
			"dependsOn": [
				"@mapsight/ui#build",
				"@mapsight/vite-host-embed#build",
				"@mapsight/traffic-style#build",
				"@mapsight/core#build",
				"@mapsight/lib-js#build",
				"@mapsight/lib-ol#build",
				"@mapsight/lib-redux#build",
				"@mapsight/vector-style-compiler#build"
			]
		}
	}
}
