{
	"name": "@mapsight/vector-editor",
	"description": "Mapsight Vector Editor",
	"version": "1.2.3",
	"private": true,
	"type": "module",
	"dependencies": {
		"@mapsight/core": "workspace:^",
		"@mapsight/lib-js": "workspace:^",
		"@mapsight/lib-ol": "workspace:^",
		"@mapsight/lib-redux": "workspace:^",
		"@mapsight/traffic-style": "workspace:^",
		"@reduxjs/toolkit": "catalog:",
		"date-fns": "^4.4.0",
		"ol": "catalog:",
		"proj4": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-modal": "^3.16.3",
		"react-redux": "catalog:",
		"react-tooltip": "^6.0.7",
		"redux-batched-actions": "catalog:",
		"redux-undo": "^1.1.0",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@mapsight/vector-style-compiler": "workspace:^",
		"@tailwindcss/postcss": "^4.3.1",
		"@types/geojson": "^7946.0.16",
		"@types/modernizr": "^3.5.6",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@types/react-modal": "^3.16.3",
		"@types/react-redux": "catalog:",
		"autoprefixer": "^10.5.0",
		"postcss-import": "^16.1.1",
		"postcss-nested": "^7.0.2",
		"vite": "^8.0.14"
	},
	"license": "MIT",
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "npm-run-all --parallel build:mapsightStyle copy --sequential build:app",
		"build:app": "vite build",
		"build:mapsightStyle": "vector-style-compiler src/mapsight/vector-style.scss --output src/generated/mapsight-vector-styles --name vector-style",
		"clean": "rimraf dist src/generated public/img/mapsight*",
		"clean-build": "run-s clean build",
		"copy": "run-p copy:*",
		"copy:traffic-style": "mkdirp public/img && cp -R node_modules/@mapsight/traffic-style/img/* public/img/",
		"dev": "npm-run-all --parallel build:mapsightStyle copy --sequential dev:app",
		"dev:app": "vite",
		"lint": "eslint",
		"start": "vite preview",
		"typecheck": "tsc --noEmit"
	}
}
