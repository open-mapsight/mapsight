{
	"name": "@mapsight/demo-next",
	"description": "Mapsight Demo Next.js",
	"version": "0.1.0",
	"private": true,
	"dependencies": {
		"@mapsight/core": "workspace:^",
		"@mapsight/lib-js": "workspace:^",
		"@mapsight/lib-ol": "workspace:^",
		"@mapsight/traffic-style": "workspace:^",
		"@mapsight/ui": "workspace:^",
		"next": "^16.2.6",
		"ol": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"reselect": "catalog:"
	},
	"devDependencies": {
		"@mapsight/vector-style-compiler": "workspace:^",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint-config-next": "16.2.6",
		"postcss": "^8.5.14",
		"sass": "^1.100.0",
		"tailwindcss": "catalog:"
	},
	"license": "UNLICENSED",
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "npm-run-all --parallel build:mapsightStyle copy --sequential build:app",
		"build:app": "next build",
		"build:mapsightStyle": "vector-style-compiler src/vector-styles/demo.scss --output src/generated/mapsight-vector-styles --name demo",
		"clean": "rimraf dist .next src/generated public/img/mapsight*",
		"clean-build": "run-s clean build",
		"copy": "run-p copy:*",
		"copy:traffic-style": "mkdirp public/img && cp -R node_modules/@mapsight/traffic-style/img/* public/img/",
		"copy:ui": "mkdirp public/img && cp -R node_modules/@mapsight/ui/dist/img/* public/img/",
		"dev": "npm-run-all --parallel build:mapsightStyle copy --sequential dev:app",
		"dev:app": "next dev",
		"lint": "eslint",
		"start": "next start",
		"typecheck": "tsc --noEmit"
	}
}
