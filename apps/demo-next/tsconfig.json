{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../configs/tsconfig-base-app.json",
	"compilerOptions": {
		"incremental": true,
		"plugins": [{"name": "next"}],
		"paths": {"@/*": ["./src/*"]}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules", "src/generated/mapsight-vector-styles/demo.js"]
}
