{
	"name": "mapsight-next-starter",
	"description": "Minimal Next.js App Router host template — copy into your app repo",
	"version": "0.1.3",
	"private": true,
	"dependencies": {
		"@mapsight/lib-js": "^3.0.7",
		"@mapsight/lib-ol": "^4.2.2",
		"@mapsight/traffic-style": "^5.4.0",
		"@mapsight/ui": "^7.4.1",
		"breakpoint-sass": "^3.0.0",
		"hint.css": "^3.0.0",
		"next": "^16.2.10",
		"ol": "^10.9.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-modal": "^3.16.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@mapsight/vector-style-compiler": "^13.0.1",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@types/react-modal": "^3.16.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"mkdirp": "^3.0.1",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.16",
		"rimraf": "^6.1.3",
		"sass": "^1.101.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^7.0.2"
	},
	"license": "MIT",
	"scripts": {
		"build": "npm-run-all prebuild copy build:mapsightStyle --sequential build:app",
		"build:app": "next build --webpack",
		"build:mapsightStyle": "vector-style-compiler src/vector-styles/demo.scss --output src/generated/mapsight-vector-styles --name demo",
		"clean": "rimraf .next src/generated public/img/mapsight*",
		"copy": "mkdirp public/img && cp -R node_modules/@mapsight/traffic-style/img/* public/img/",
		"dev": "npm-run-all prebuild copy build:mapsightStyle --sequential dev:app",
		"dev:app": "next dev --webpack",
		"prebuild": "node scripts/sync-workspace-mapsight.mts",
		"start": "next start",
		"typecheck": "npm-run-all build:mapsightStyle --sequential typecheck:app",
		"typecheck:app": "tsc --noEmit"
	}
}
