{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../configs/tsconfig-base-tsx.json",
	"include": ["src/js/**/*"],
	"exclude": ["src/js/**/*.test.ts", "src/js/**/__tests__/**"],
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src/js",
		// FIXME
		"strict": false,
		"strictNullChecks": true,
		"noUncheckedIndexedAccess": true,
		// FIXME: Convert js to ts
		"checkJs": false
	}
}
