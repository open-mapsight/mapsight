{
	"name": "@mapsight/ui",
	"description": "Mapsight UI for map based web applications using React and Redux",
	"version": "7.3.1",
	"type": "module",
	"dependencies": {
		"@mapsight/core": "workspace:^",
		"@mapsight/lib-js": "workspace:^",
		"@mapsight/lib-ol": "workspace:^",
		"@mapsight/lib-redux": "workspace:^",
		"@mapsight/traffic-style": "workspace:^",
		"@reduxjs/toolkit": "catalog:",
		"@types/react-redux": "catalog:",
		"breakpoint-sass": "^3.0.0",
		"flatpickr": "^4.6.13",
		"focus-trap-react": "^12.0.2",
		"hint.css": "^3.0.0",
		"jsdom": "catalog:",
		"lodash": "catalog:",
		"ol": "catalog:",
		"proj4": "catalog:",
		"react-aria": "^3.49.0",
		"react-intersection-observer": "^10.0.3",
		"react-modal": "^3.16.3",
		"react-paginate": "^8.3.0",
		"react-redux": "catalog:",
		"redux-batched-actions": "catalog:",
		"redux-thunk": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@tanstack/react-query": "^5.90.5",
		"@testing-library/react": "^16.3.2",
		"@types/lodash": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@types/react-modal": "^3.16.3",
		"chokidar": "^5.0.0",
		"react": "catalog:",
		"react-dom": "catalog:",
		"svgo": "^4.0.1",
		"vitest": "catalog:"
	},
	"exports": {
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		},
		"./*.png": {
			"default": "./dist/*.png"
		},
		"./*.svg": {
			"default": "./dist/*.svg"
		},
		"./config": {
			"types": "./dist/config/index.d.ts",
			"default": "./dist/config/index.js"
		},
		"./async-status": {
			"types": "./dist/lib/async-status/index.d.ts",
			"default": "./dist/lib/async-status/index.js"
		},
		"./async-status/components": {
			"types": "./dist/components/async-status/index.d.ts",
			"default": "./dist/components/async-status/index.js"
		},
		"./react-query": {
			"types": "./dist/react-query/index.d.ts",
			"default": "./dist/react-query/index.js"
		},
		"./config/*": {
			"types": "./dist/config/*.d.ts",
			"default": "./dist/config/*.js"
		},
		"./helpers/i18n": {
			"types": "./dist/helpers/i18n/index.d.ts",
			"default": "./dist/helpers/i18n/index.js"
		},
		"./config/schema/*": {
			"types": "./dist/config/schema/*.d.ts",
			"default": "./dist/config/schema/*.js"
		},
		"./embed/*": {
			"types": "./dist/embed/*.d.ts",
			"default": "./dist/embed/*.js"
		}
	},
	"files": [
		"dist",
		"src/scss"
	],
	"license": "MIT",
	"peerDependencies": {
		"@tanstack/react-query": "^5.90.5",
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"peerDependenciesMeta": {
		"@tanstack/react-query": {
			"optional": true
		}
	},
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "npm-run-all build:setup --parallel build:images build:modules",
		"build:images": "mkdirp dist/img/mapsight-ui && svgo --multipass --quiet -rf ./src/img/mapsight-ui/ -o ./dist/img/mapsight-ui/",
		"build:modules": "tsc",
		"build:setup": "mkdirp dist",
		"clean": "rimraf dist/*",
		"clean-build": "run-s clean build",
		"lint": "eslint",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"watch": "run-s build:modules watch:build",
		"watch:build": "run-p watch:build:*",
		"watch:build:modules": "tsc --watch"
	}
}
