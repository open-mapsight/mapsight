{
	"name": "@mapsight/count-aggregator-api",
	"description": "OpenAPI contract, Zod schemas, and typed client for Mapsight count aggregator",
	"version": "1.1.0",
	"type": "module",
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"npm-run-all": "^4.1.5",
		"openapi-zod-client": "^1.18.3",
		"rimraf": "^6.1.3",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./openapi.json": "./openapi/count-aggregator.openapi.json"
	},
	"files": [
		"dist",
		"openapi"
	],
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"clean": "rimraf dist",
		"clean-build": "run-s clean build",
		"generate": "node scripts/generate.ts",
		"lint": "eslint",
		"prebuild": "pnpm generate",
		"sync-openapi": "node --env-file=.env scripts/sync-openapi.ts",
		"test": "vitest run",
		"test:smoke": "SMOKE_COUNT_AGGREGATOR_API=1 node --env-file-if-exists=.env node_modules/vitest/vitest.mjs run --config vitest.smoke.config.ts",
		"typecheck": "run-s typecheck:lib typecheck:test",
		"typecheck:lib": "tsc --noEmit",
		"typecheck:test": "tsc --noEmit -p tsconfig.test.json",
		"watch": "run-s build watch:build",
		"watch:build": "tsc --project tsconfig.build.json --watch"
	}
}
