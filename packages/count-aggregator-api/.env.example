# Copy to `.env` for local maintenance tasks (not required for build or unit tests).

# Live OpenAPI JSON used by `pnpm sync-openapi`
# Example: https://<tenant>.example.tld/msp/public/count-aggregator/openapi.json
COUNT_AGGREGATOR_OPENAPI_URL=

# Public API base URL used by opt-in smoke tests (`pnpm test:smoke`)
# Example: https://<tenant>.example.tld/msp/public/count-aggregator
COUNT_AGGREGATOR_API_BASE=
