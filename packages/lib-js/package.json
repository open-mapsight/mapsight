{
	"name": "@mapsight/lib-js",
	"description": "Mapsight JS Library",
	"version": "3.0.5",
	"type": "module",
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/modernizr": "^3.5.6",
		"mkdirp": "^3.0.1",
		"npm-run-all": "^4.1.5",
		"vitest": "catalog:"
	},
	"exports": {
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json --outDir dist",
		"clean": "rm -rf dist",
		"clean-build": "run-s clean build",
		"lint": "eslint",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"watch": "run-s build watch:build",
		"watch:build": "tsc --project tsconfig.build.json --outDir dist --watch"
	}
}
