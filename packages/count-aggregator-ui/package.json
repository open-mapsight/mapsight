{
	"name": "@mapsight/count-aggregator-ui",
	"description": "React chart and wizard UI for Mapsight count aggregator applications",
	"version": "2.0.1",
	"type": "module",
	"dependencies": {
		"@mapsight/count-aggregator-api": "workspace:^",
		"@tanstack/react-query": "^5.90.5",
		"clsx": "^2.1.1",
		"flatpickr": "^4.6.13",
		"react-flatpickr": "^4.0.11",
		"recharts": "^2.15.4",
		"tailwind-merge": "^3.3.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@mapsight/ui": "workspace:^",
		"@tailwindcss/cli": "^4.3.0",
		"@testing-library/react": "^16.3.2",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@types/react-flatpickr": "^3.8.11",
		"npm-run-all": "^4.1.5",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-select": "^5.10.2",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./headless": {
			"types": "./dist/headless.d.ts",
			"default": "./dist/headless.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"peerDependencies": {
		"@mapsight/ui": "workspace:^",
		"@tanstack/react-query": "^5.90.5",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-select": "^5.10.2"
	},
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "run-s build:css build:modules",
		"build:css": "mkdir -p dist && tailwindcss -i src/styles.css -o dist/styles.css --minify",
		"build:modules": "tsc --project tsconfig.build.json",
		"clean": "rimraf dist",
		"clean-build": "run-s clean build",
		"lint": "eslint",
		"test": "vitest run",
		"typecheck": "run-s typecheck:lib typecheck:test",
		"typecheck:lib": "tsc --noEmit",
		"typecheck:test": "tsc --noEmit -p tsconfig.test.json",
		"watch": "run-s build watch:build",
		"watch:build": "run-p watch:css watch:modules",
		"watch:css": "mkdir -p dist && tailwindcss -i src/styles.css -o dist/styles.css --watch",
		"watch:modules": "tsc --project tsconfig.build.json --watch"
	}
}
