{
	"name": "@mapsight/vector-style-compiler",
	"description": "Mapsight Vector Style Compiler",
	"version": "12.1.2",
	"type": "module",
	"bin": {
		"vector-style-compiler": "./bin/vector-style-compiler.js"
	},
	"dependencies": {
		"@mapsight/lib-js": "workspace:^",
		"@types/lodash": "catalog:",
		"@types/node": "catalog:",
		"chokidar": "^5.0.0",
		"lodash": "catalog:",
		"postcss": "^8.5.15",
		"sass": "^1.101.0"
	},
	"devDependencies": {
		"@mapsight/core": "workspace:^",
		"@mapsight/lib-ol": "workspace:^",
		"@types/pidusage": "^2.0.5",
		"fs-extra": "^11.3.5",
		"json": "^11.0.0",
		"mkdirp": "^3.0.1",
		"pidtree": "^1.0.0",
		"pidusage": "catalog:",
		"playwright": "catalog:",
		"replace-in-file": "^8.4.0",
		"vite": "^8.0.14",
		"vitest": "catalog:"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./mapsight-vector-style.css-data.json": "./dist/mapsight-vector-style.css-data.json",
		"./mapsight-vector-style.web-types.json": "./dist/mapsight-vector-style.web-types.json",
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		}
	},
	"files": [
		"dist",
		"bin"
	],
	"license": "MIT",
	"main": "./dist/index.js",
	"peerDependencies": {
		"@mapsight/core": "workspace:^",
		"@mapsight/lib-ol": "workspace:^",
		"ol": "catalog:"
	},
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"bench": "node __tests__/performance.engines.bench.ts",
		"bench:render": "node __tests__/render-backends.bench.ts",
		"bench:render:samples": "node scripts/run-render-benchmark-samples.mts",
		"build": "run-s build:setup build:modules generate:ide-metadata copy:templates copy:ide-metadata",
		"build:modules": "tsc -p tsconfig.build.json",
		"build:setup": "mkdirp dist",
		"clean": "rimraf dist",
		"clean-build": "run-s clean build",
		"copy": "run-p copy:*",
		"copy:ide-metadata": "cp src/data/generated/* dist/",
		"copy:templates": "cp src/js/template.source.js dist/template.source.js",
		"data:sort-custom-css-properties": "json -I -f src/data/custom-css-properties.json -o jsony-tab -e 'this.sort((a, b) => a.name.localeCompare(b.name))' -A",
		"generate:ide-metadata": "node scripts/update-ide-metadata.mts",
		"lint": "eslint",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"update-readme": "node scripts/update-readme.mts",
		"watch": "run-s copy:templates \"tsc -p tsconfig.build.json --watch\""
	},
	"types": "./dist/index.d.ts",
	"web-types": "./dist/mapsight-vector-style.web-types.json"
}
