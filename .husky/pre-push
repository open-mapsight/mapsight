#!/usr/bin/env sh

remote="$1"
push_data=""

while read -r local_ref local_sha remote_ref remote_sha; do
	[ -z "$local_ref" ] && continue
	push_data="${push_data}${local_ref} ${local_sha} ${remote_ref} ${remote_sha}
"
done

if [ "$remote" = "private" ]; then
	exit 0
fi

blocked=""

while read -r local_ref local_sha remote_ref remote_sha; do
	[ -z "$local_ref" ] && continue

	if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	local_branch="${local_ref#refs/heads/}"
	remote_branch="${remote_ref#refs/heads/}"

	case "$local_branch" in
	private/*)
		blocked="${blocked}
  - ${local_branch}"
		;;
	esac

	case "$remote_branch" in
	private/*)
		if ! printf '%s' "$blocked" | grep -Fq "  - ${remote_branch}"; then
			blocked="${blocked}
  - ${remote_branch}"
		fi
		;;
	esac
done <<EOF
${push_data}
EOF

if [ -n "$blocked" ]; then
	echo "error: refusing to push private branches to remote '$remote'."
	echo "Use the private remote instead, for example:"
	echo "  git push private <branch>"
	printf 'Blocked branch(es):%s\n' "$blocked"
	exit 1
fi

printf '%s' "$push_data" | node scripts/check-no-private-leak.mts --mode push --visibility public --remote "$remote"
