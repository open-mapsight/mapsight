{
	"name": "@mapsight/root",
	"private": true,
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^9.39.4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/geojson": "^7946.0.16",
		"@types/node": "catalog:",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-n": "^18.0.1",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"lint-staged": "^17.0.5",
		"mkdirp": "^3.0.1",
		"npm-run-all": "^4.1.5",
		"playwright": "catalog:",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"syncpack": "^15.1.2",
		"turbo": "^2.9.14",
		"typescript": "catalog:",
		"typescript-eslint": "^8.59.3"
	},
	"engines": {
		"node": "^24.15.0",
		"pnpm": "^11.1.2"
	},
	"license": "UNLICENSED",
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build": "turbo build",
		"clean": "turbo clean",
		"clean-build": "turbo clean && turbo build",
		"format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,mts,cts,tsx,json,md}\"",
		"format:write": "prettier --write \"**/*.{js,mjs,cjs,ts,mts,cts,tsx,json,md}\"",
		"lint": "turbo lint",
		"lint-staged": "pnpx lint-staged --config configs/lint-staged.mts",
		"prepare": "husky",
		"publish": "pnpm changeset publish",
		"release": "run-s build publish",
		"syncpack:fix": "syncpack fix --config configs/syncpack.config.ts",
		"syncpack:fix-and-format": "run-s syncpack:fix syncpack:format:write",
		"syncpack:format:check": "syncpack format --check --config configs/syncpack.config.ts",
		"syncpack:format:write": "syncpack format --config configs/syncpack.config.ts",
		"syncpack:lint": "syncpack lint --config configs/syncpack.config.ts",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"watch": "turbo watch watch"
	}
}
