{
	"name": "@mapsight/root",
	"private": true,
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "catalog:",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/geojson": "^7946.0.16",
		"@types/node": "catalog:",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-n": "^18.1.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"lint-staged": "^17.0.7",
		"mkdirp": "^3.0.1",
		"npm-run-all": "^4.1.5",
		"playwright": "catalog:",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"syncpack": "^15.3.1",
		"turbo": "^2.9.18",
		"typescript": "catalog:",
		"typescript-eslint": "^8.61.0"
	},
	"engines": {
		"node": "^24.15.0",
		"pnpm": "^11.1.2"
	},
	"license": "UNLICENSED",
	"packageManager": "pnpm@11.1.2",
	"repository": {
		"url": "https://github.com/open-mapsight/mapsight"
	},
	"scripts": {
		"build": "turbo build",
		"check": "run-p check:no-private-leak check:starter-pins",
		"check:no-private-leak": "node scripts/check-no-private-leak.mts",
		"check:starter-pins": "node scripts/check-starter-package-pins.mts",
		"check:typecheck-test-coverage": "node scripts/check-typecheck-test-coverage.mts",
		"clean": "turbo clean",
		"clean-build": "run-s clean build",
		"format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,mts,cts,tsx,json,md}\"",
		"format:write": "prettier --write \"**/*.{js,mjs,cjs,ts,mts,cts,tsx,json,md}\"",
		"lint": "turbo run lint //#lint:starters",
		"lint-staged": "pnpx lint-staged --config configs/lint-staged.mts",
		"lint:starters": "run-s lint:starters:prepare sync:workspace-mapsight lint:starters:eslint",
		"lint:starters:eslint": "eslint -c starters/eslint.config.mts starters/mapsight-host-starter starters/mapsight-next-starter starters/mapsight-vite-spa-starter",
		"lint:starters:prepare": "run-s lint:starters:prepare:styles",
		"lint:starters:prepare:styles": "run-s lint:starters:prepare:styles:host lint:starters:prepare:styles:next lint:starters:prepare:styles:vite-spa",
		"lint:starters:prepare:styles:host": "pnpm --dir starters/mapsight-host-starter run build:mapsightStyle",
		"lint:starters:prepare:styles:next": "pnpm --dir starters/mapsight-next-starter run build:mapsightStyle",
		"lint:starters:prepare:styles:vite-spa": "pnpm --dir starters/mapsight-vite-spa-starter run build:mapsightStyle",
		"lint:workspace": "turbo lint",
		"prepare": "husky",
		"publish": "changeset publish",
		"release": "run-s build publish",
		"sync:starter-pins": "node scripts/sync-starter-package-pins.mts",
		"sync:workspace-mapsight": "run-s sync:workspace-mapsight:host sync:workspace-mapsight:next sync:workspace-mapsight:vite-spa",
		"sync:workspace-mapsight:host": "node scripts/sync-workspace-mapsight.mts starters/mapsight-host-starter",
		"sync:workspace-mapsight:next": "node scripts/sync-workspace-mapsight.mts starters/mapsight-next-starter",
		"sync:workspace-mapsight:vite-spa": "node scripts/sync-workspace-mapsight.mts starters/mapsight-vite-spa-starter",
		"syncpack:fix": "syncpack fix --config configs/syncpack.config.ts",
		"syncpack:fix-and-format": "run-s syncpack:fix syncpack:format:write",
		"syncpack:format:check": "syncpack format --check --config configs/syncpack.config.ts",
		"syncpack:format:write": "syncpack format --config configs/syncpack.config.ts",
		"syncpack:lint": "syncpack lint --config configs/syncpack.config.ts",
		"test": "turbo test",
		"test:starters:copy-out": "node scripts/smoke-starter-copy-out.mts",
		"test:starters:e2e": "playwright test -c e2e/starters/playwright.config.ts",
		"typecheck": "turbo run typecheck //#typecheck:scripts",
		"typecheck:scripts": "run-p typecheck:scripts:root typecheck:scripts:starters",
		"typecheck:scripts:root": "tsc --noEmit -p scripts/tsconfig.json",
		"typecheck:scripts:starters": "run-s sync:workspace-mapsight typecheck:scripts:starters:tsc",
		"typecheck:scripts:starters:tsc": "tsc --noEmit -p starters/tsconfig.json",
		"version-packages": "changeset version && pnpm run sync:starter-pins",
		"watch": "turbo watch watch"
	}
}
